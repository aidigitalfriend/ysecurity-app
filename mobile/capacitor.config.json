{
  "appId": "com.ysecurity.app",
  "appName": "Ysecurity",
  "webDir": "build",
  "bundledWebRuntime": false,
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_shield",
      "iconColor": "#1a73e8"
    },
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#0a0a1a",
      "showSpinner": false
    },
    "BackgroundGeolocation": {
      "url": "https://ysecurity.app/api/location",
      "autoSync": true,
      "syncInterval": 60,
      "maxLocations": 10000,
      "debug": false
    }
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0a0a1a"
  }
}
